# Alpaca API (Paper Trading)
APCA_API_KEY_ID=your_paper_key_here
APCA_API_SECRET_KEY=your_paper_secret_here
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# Alpaca API (Live Trading) — uncomment when ready
# APCA_LIVE_API_KEY_ID=your_live_key_here
# APCA_LIVE_API_SECRET_KEY=your_live_secret_here
# APCA_LIVE_API_BASE_URL=https://api.alpaca.markets

# TimescaleDB
TIMESCALEDB_HOST=localhost
TIMESCALEDB_PORT=5432
TIMESCALEDB_USER=opentrade
TIMESCALEDB_PASSWORD=changeme
TIMESCALEDB_NAME=opentrade

# Notifications (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# DISCORD_WEBHOOK_URL=

# LLM AI (optional — for adversarial debate)
# LLM_ENABLED=true
# LLM_BASE_URL=https://api.openai.com  # or http://localhost:11434 for Ollama
# LLM_MODEL=gpt-4o-mini
# LLM_MIN_CONFIDENCE=0.6
# LLM_API_KEY=sk-or-your-openrouter-key-here
