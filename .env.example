# Alpaca API (Paper Trading)
APCA_API_KEY_ID=your_paper_key_here
APCA_API_SECRET_KEY=your_paper_secret_here
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# Alpaca Market Data — separate paid credentials (optional)
# Use your paid/live account keys here to get real-time trade ticks
# while trading on paper. Falls back to the keys above if not set.
# APCA_DATA_API_KEY_ID=your_paid_key_here
# APCA_DATA_API_SECRET_KEY=your_paid_secret_here

# Alpaca API (Live Trading) — uncomment when ready
# APCA_LIVE_API_KEY_ID=your_live_key_here
# APCA_LIVE_API_SECRET_KEY=your_live_secret_here
# APCA_LIVE_API_BASE_URL=https://api.alpaca.markets

# TimescaleDB
TIMESCALEDB_HOST=localhost
TIMESCALEDB_PORT=5432
TIMESCALEDB_USER=opentrade
TIMESCALEDB_PASSWORD=changeme
TIMESCALEDB_NAME=opentrade

# Notifications (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# DISCORD_WEBHOOK_URL=

# LLM AI — OpenRouter (adversarial debate system)
# Sign up at https://openrouter.ai/ and create an API key
LLM_ENABLED=true
LLM_BASE_URL=https://openrouter.ai/api
LLM_MODEL=anthropic/claude-sonnet-4
LLM_MIN_CONFIDENCE=0.6
LLM_API_KEY=sk-or-your-openrouter-key-here
